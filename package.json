{
  "name": "outlay",
  "version": "1.2.0",
  "description": "Off-DOM CSS layout solver — computes Flexbox and CSS Grid positions and sizes without a browser",
  "keywords": [
    "css",
    "flexbox",
    "grid",
    "css-grid",
    "layout",
    "solver",
    "off-dom",
    "positioning",
    "layout-testing"
  ],
  "author": "Alec Custer",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "default": "./dist/testing.js"
    },
    "./html": {
      "types": "./dist/html.d.ts",
      "import": "./dist/html.js",
      "default": "./dist/html.js"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "import": "./dist/text.js",
      "default": "./dist/text.js"
    },
    "./pretext": {
      "types": "./dist/pretext.d.ts",
      "import": "./dist/pretext.js",
      "default": "./dist/pretext.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/runner.ts",
    "test:trace": "tsx tests/trace-comparator.test.ts",
    "test:validate": "tsx tests/validate.test.ts",
    "test:api": "tsx tests/api.test.ts",
    "test:testing": "tsx tests/testing.test.ts",
    "test:text": "tsx tests/text.test.ts",
    "test:html": "tsx tests/html.test.ts",
    "test:example": "npm run build && npm --prefix examples/layout-assertions install && npm --prefix examples/layout-assertions test",
    "generate": "tsx tests/generator.ts",
    "probe": "tsx scripts/probe-chromium.ts",
    "prepack": "npm run build",
    "bench": "tsx scripts/benchmark.ts",
    "package-smoke-test": "tsx scripts/package-smoke-test.ts",
    "start": "vite",
    "site:build": "vite build --base=/outlay/ && mkdir -p site/demos/server-layout && cp pages/demos/server-layout/example-output.svg site/demos/server-layout/",
    "demo:server-layout": "tsx pages/demos/server-layout/generate.ts",
    "verify:explorer": "tsx scripts/verify-explorer.ts",
    "verify:text-demo": "tsx scripts/verify-text-demo.ts"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@types/node": "^25.5.2",
    "@types/puppeteer": "^5.4.7",
    "puppeteer": "^24.40.0",
    "taffy-layout": "^2.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alechemy/outlay.git"
  },
  "homepage": "https://alechemy.github.io/outlay/",
  "bugs": {
    "url": "https://github.com/alechemy/outlay/issues"
  },
  "dependencies": {
    "htmlparser2": "^12.0.0"
  },
  "peerDependencies": {
    "@chenglou/pretext": "^0.0.8"
  },
  "peerDependenciesMeta": {
    "@chenglou/pretext": {
      "optional": true
    }
  }
}
