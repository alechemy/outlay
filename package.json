{
  "name": "constraint-layout-algo",
  "version": "1.0.0",
  "description": "Off-DOM CSS layout solver — computes Flexbox positions and sizes without a browser",
  "keywords": [
    "css",
    "flexbox",
    "layout",
    "solver",
    "off-dom",
    "positioning"
  ],
  "author": "Alec Custer",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "tsx tests/runner.ts",
    "test:trace": "tsx tests/trace-comparator.test.ts",
    "generate": "tsx tests/generator.ts",
    "probe": "tsx scripts/probe-chromium.ts",
    "bench": "tsx scripts/benchmark.ts",
    "package-smoke-test": "tsx scripts/package-smoke-test.ts",
    "start": "vite",
    "verify:explorer": "tsx scripts/verify-explorer.ts",
    "verify:text-demo": "tsx scripts/verify-text-demo.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/puppeteer": "^5.4.7",
    "htmlparser2": "^12.0.0",
    "puppeteer": "^24.40.0",
    "taffy-layout": "^2.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
